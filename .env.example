APP_ENV=development
ENV_DIR=.

# Server
SERVER_GRPC_PORT=50051
SERVER_HTTP_PORT=8080
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_MAX_CONNECTIONS=1000
SERVER_CONNECTION_TIMEOUT=10s

# Specialist Database (Postgres)
POSTGRES_HOST=postgres-specialist
POSTGRES_PORT=5432
POSTGRES_USER=healing_specialist
POSTGRES_PASSWORD=healing_specialist
POSTGRES_DB=healing_specialist
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLE_TIME=2m

# Auth Database (Postgres dedicado)
AUTH_POSTGRES_HOST=postgres-auth
AUTH_POSTGRES_PORT=5432
AUTH_POSTGRES_USER=healing_auth
AUTH_POSTGRES_PASSWORD=healing_auth
AUTH_POSTGRES_DB=healing_auth
AUTH_POSTGRES_SSLMODE=disable
AUTH_POSTGRES_MAX_OPEN_CONNS=10
AUTH_POSTGRES_MAX_IDLE_CONNS=5
AUTH_POSTGRES_CONN_MAX_LIFETIME=5m
AUTH_POSTGRES_CONN_MAX_IDLE_TIME=1m

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

# SQS (LocalStack em dev, AWS real em prod)
SQS_REGION=us-east-1
SQS_QUEUE_PREFIX=specialist
SQS_ENDPOINT=http://localstack:4566

# SNS (LocalStack em dev, AWS real em prod)
SNS_REGION=us-east-1
SNS_ENDPOINT=http://localstack:4566
SNS_TOPIC_PREFIX=specialist

# OpenSearch
OPENSEARCH_ADDRESSES=http://opensearch:9200
OPENSEARCH_REGION=
OPENSEARCH_INDEX_PREFIX=healing

# External Services
LICENSE_VALIDATION_BASE_URL=http://host.docker.internal:3001

# Email (MailHog em dev, SES em prod)
EMAIL_SMTP_HOST=mailhog
EMAIL_SMTP_PORT=1025
EMAIL_FROM_ADDRESS=noreply@healing.local
EMAIL_FROM_NAME=Healing Platform

# Observability (OTel)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=healing-specialist
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# Auth Tokens (JWT RSA)
AUTH_PRIVATE_KEY_PATH=/etc/healing/keys/auth-private.pem
AUTH_PUBLIC_KEY_PATH=/etc/healing/keys/auth-public.pem
AUTH_CURRENT_KEY_ID=healing-2026-05
AUTH_ACCESS_TOKEN_TTL=1h
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_SET_PASSWORD_TTL=24h
AUTH_RESET_PASSWORD_TTL=1h
AUTH_SET_PASSWORD_BASE_URL=http://localhost:3000/set-password
AUTH_ISSUER=healing-specialist
AUTH_AUDIENCE=healing-platform
AUTH_BCRYPT_COST=12
AUTH_PASSWORD_MIN_LENGTH=8
