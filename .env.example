# ========================================
# Healing Specialist - Stack Configuration
# ========================================
# Use estas variáveis para conectar suas aplicações aos serviços da stack de desenvolvimento

# ========================================
# PostgreSQL Database
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=healing_specialist_db
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/healing_specialist_db

# ========================================
# Kafka Message Broker
# ========================================
KAFKA_BROKER=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ========================================
# OpenTelemetry Collector
# ========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=your-service-name

# OTLP gRPC (alternativa)
OTEL_EXPORTER_OTLP_GRPC_ENDPOINT=http://localhost:4317

# ========================================
# Observability Stack (Read-only)
# ========================================
# Grafana Dashboard
GRAFANA_URL=http://localhost:3000

# Prometheus Metrics
PROMETHEUS_URL=http://localhost:9090

# Tempo Traces
TEMPO_URL=http://localhost:3200

# Loki Logs
LOKI_URL=http://localhost:3100

# ========================================
# Kafka UI (Read-only)
# ========================================
KAFKA_UI_URL=http://localhost:8080
