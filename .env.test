SERVER_GRPC_PORT=50051
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_MAX_CONNECTIONS=1000
SERVER_CONNECTION_TIMEOUT=10s

POSTGRES_HOST=postgres-test
POSTGRES_PORT=5432
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=healing_specialist_test_db
POSTGRES_SSLMODE=disable

KAFKA_BOOTSTRAP_SERVERS=broker-test:9092
KAFKA_AUTO_OFFSET_RESET=earliest

OTEL_SERVICE_NAME=healing-specialist
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=test
OTEL_EXPORTER_OTLP_GRPC_ENDPOINT=otel-collector:5317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
