                        }
                    }
                }
            }
        },
        "/api/v1/specialists/{id}": {
            "patch": {
                "description": "Partially updates a specialist's profile data. Only provided fields are updated (PATCH semantics).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "specialists"
                ],
                "summary": "Update a specialist",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Specialist UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Fields to update",
                        "name": "request",
                        "in": "body",
                        "required": true,
