                            "$ref": "#/definitions/internal_modules_auth_features_set-password_adapters_inbound_http_handler.SetPasswordResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid payload or weak password",
                        "schema": {
                            "$ref": "#/definitions/internal_modules_auth_features_set-password_adapters_inbound_http_handler.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Invalid or already used token",
                        "schema": {
                            "$ref": "#/definitions/internal_modules_auth_features_set-password_adapters_inbound_http_handler.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Credential not in pending state",
                        "schema": {
