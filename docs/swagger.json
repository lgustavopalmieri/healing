                        "schema": {
                            "$ref": "#/definitions/internal_modules_auth_features_refresh-token_adapters_inbound_http_handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/set-password": {
            "post": {
                "description": "Consumes a single-use set-password token, activates the credential, and returns access/refresh tokens. The token is issued during onboarding and can be used only once.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Set initial password for a pending credential",
                "parameters": [
                    {
                        "description": "Set-password payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_modules_auth_features_set-password_adapters_inbound_http_handler.SetPasswordRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
